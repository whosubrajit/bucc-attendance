# ── Database ────────────────────────────────────────────────
# Supabase: use the "Transaction" pooler URL (port 6543) for DATABASE_URL
# and the direct URL (port 5432) for DIRECT_URL (used by migrations).
DATABASE_URL="postgresql://user:pass@localhost:5432/bucc_attendance?schema=public"
DIRECT_URL="postgresql://user:pass@localhost:5432/bucc_attendance?schema=public"

# ── Auth (NextAuth + Google OAuth) ──────────────────────────
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Only this email domain may sign in (enforced server-side)
ALLOWED_EMAIL_DOMAIN="g.bracu.ac.bd"

# ── QR signing ──────────────────────────────────────────────
# HMAC key for QR session tokens. Rotate to invalidate all QR codes.
QR_SIGNING_SECRET="generate-with: openssl rand -hex 32"

# ── Cron (auto-timeout escalation) ──────────────────────────
# Vercel Cron / external scheduler must send: Authorization: Bearer {CRON_SECRET}
CRON_SECRET="generate-with: openssl rand -hex 24"

# ── Email (optional — notifications degrade gracefully) ─────
RESEND_API_KEY=""
EMAIL_FROM="BUCC Attendance <attendance@bucc.club>"

# ── Central Member Database sync (optional) ─────────────────
# If set, "Sync from Central DB" in the admin panel fetches members from this
# JSON endpoint. Otherwise the CentralMember table (seeded via prisma/seed.ts)
# acts as the central database.
CENTRAL_DB_API_URL=""
CENTRAL_DB_API_KEY=""

# ── Manual check-in geofence (optional) ─────────────────────
# BRACU campus coordinates + allowed radius in meters for manual check-in.
# Leave CAMPUS_RADIUS_M empty to disable geofencing.
CAMPUS_LAT="23.7808875"
CAMPUS_LNG="90.4074434"
CAMPUS_RADIUS_M="500"
